flowchart TD
    Q["User Question q"] --> TOK["Tokenize + Embed\nvia LM Embedding Layer"]
    TOK --> POOL["Mean Pool\nto get q_bar"]
    POOL --> MLP["2-Layer MLP\nScope Classifier"]

    MLP --> CONF{"Confidence\n>= 0.6?"}
    CONF -->|"Yes"| PRED["Predicted Scope c"]
    CONF -->|"No"| FALLBACK["Default: HISTORICAL\nfull memory access"]

    PRED --> INSTANT{"c = INSTANT"}
    PRED --> RECENT{"c = RECENT"}
    PRED --> HIST{"c = HISTORICAL"}

    INSTANT --> M1["Mask: only most\nrecent entry + live frame"]
    RECENT --> M2["Mask: entries within\nlast W=30 seconds"]
    HIST --> M3["Mask: all entries\nunmasked"]
    FALLBACK --> M3

    M1 --> OUT["Attention Mask m\npassed to SFG"]
    M2 --> OUT
    M3 --> OUT
